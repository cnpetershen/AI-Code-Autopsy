{
  "name": "@ai-code-autopsy/core",
  "version": "1.0.0",
  "private": false,
  "description": "Core forensic engine for AI-generated code pattern detection and risk scoring",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ai-code-autopsy"
  },
  "keywords": [
    "ai-detection",
    "code-forensic",
    "code-analysis",
    "ast",
    "ai-code",
    "developer-tools"
  ],
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@babel/generator": "^7.24.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/babel__generator": "^7.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
